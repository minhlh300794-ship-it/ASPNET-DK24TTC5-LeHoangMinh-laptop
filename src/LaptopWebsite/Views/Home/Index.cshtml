@model IEnumerable<LaptopWebsite.Models.Product>
@{ ViewBag.Title = "Trang chủ"; }

<div class="card shadow-sm border-0 bg-light mt-4 mb-4">
    <div class="card-body">
        <form action="@Url.Action("Index", "Home")" method="get">
            <div class="row g-2 align-items-center">
                <div class="col-md-5">
                    <input type="text" name="searchString" value="@ViewBag.CurrentSearch" class="form-control" placeholder="Nhập tên laptop cần tìm..." />
                </div>
                <div class="col-md-4">
                    @Html.DropDownList("categoryId", null, "--- Tất cả thương hiệu ---", new { @class = "form-select" })
                </div>
                <div class="col-md-3">
                    <button type="submit" class="btn btn-primary w-100"><i class="fas fa-search"></i> Tìm kiếm</button>
                </div>
            </div>
        </form>
    </div>
</div>

@if (string.IsNullOrEmpty(ViewBag.CurrentSearch) && Request.QueryString["categoryId"] == null)
{
    <div id="heroCarousel" class="carousel slide mb-5 shadow-sm rounded" data-bs-ride="carousel">
        <div class="carousel-indicators">
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
            <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
        </div>
        <div class="carousel-inner rounded">
            <div class="carousel-item active">
                <img src="https://i.ibb.co/Kxr2K6WF/asus-giam-gia.jpg" alt="asus giam gia" border="0">
            </div>
            
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon"></span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon"></span>
        </button>
    </div>
}

<h3 class="fw-bold mb-4 border-bottom pb-2">Laptop Nổi Bật</h3>

<div class="row">
    @if (Model != null && Model.Any())
    {
        foreach (var item in Model)
        {
            <div class="col-lg-3 col-md-4 col-sm-6 mb-4">
                <div class="card h-100 product-card shadow-sm border-0">
                    <img src="@item.ImageUrl" class="card-img-top p-3" alt="@item.ProductName" style="object-fit: contain; height: 220px;">
                    <div class="card-body d-flex flex-column text-center pt-0">
                        <h6 class="card-title fw-bold text-dark mb-2" style="min-height: 40px;">@item.ProductName</h6>
                        <h5 class="text-danger fw-bold mb-3">@item.Price.ToString("N0") đ</h5>

                        <div class="mt-auto">
                            <a href="@Url.Action("AddToCart", "Cart", new { id = item.ProductId })" class="btn btn-primary w-100 mb-2 rounded-pill">
                                <i class="fas fa-cart-plus"></i> Thêm vào giỏ
                            </a>
                            <a href="@Url.Action("Details", "Home", new { id = item.ProductId })" class="btn btn-outline-secondary w-100 rounded-pill">
                                Chi tiết
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="col-12 text-center my-5">
            <h5 class="text-muted">Không tìm thấy sản phẩm nào!</h5>
        </div>
    }
</div>