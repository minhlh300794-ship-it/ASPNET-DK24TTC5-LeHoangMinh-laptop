@model LaptopWebsite.Models.Product

@{
    ViewBag.Title = Model.ProductName;
}

<div class="container mt-5">
    <div class="row">
        <div class="col-md-6 mb-4">
            <img src="@Model.ImageUrl" alt="@Model.ProductName" class="img-fluid rounded shadow-sm" style="width: 100%; object-fit: cover;" />
        </div>

        <div class="col-md-6">
            <h2 class="font-weight-bold">@Model.ProductName</h2>
            <h4 class="text-danger mb-3">@Model.Price.ToString("N0") VNĐ</h4>

            <hr />

            <p><strong>Thương hiệu:</strong> @Model.Category.CategoryName</p>
            <p>
                <strong>Tình trạng:</strong>
                @if (Model.StockQuantity > 0)
                {
                    <span class="badge badge-success text-success">Còn hàng (@Model.StockQuantity)</span>
                }
                else
                {
                    <span class="badge badge-danger text-danger">Hết hàng</span>
                }
            </p>

            <h5 class="mt-4">Cấu hình chi tiết:</h5>
            <p class="text-muted" style="white-space: pre-line;">@Model.Description</p>

            <div class="mt-4">
                <a href="@Url.Action("AddToCart", "Cart", new { id = @Model.ProductId })" class="btn btn-primary btn-lg">
                    <i class="fas fa-shopping-cart"></i> Thêm vào giỏ hàng
                </a>
                <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary btn-lg">
                    Quay lại
                </a>
            </div>
        </div>
    </div>
</div>