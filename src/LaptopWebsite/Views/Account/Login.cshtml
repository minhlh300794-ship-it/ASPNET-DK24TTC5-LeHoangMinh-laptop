@{
    ViewBag.Title = "Đăng nhập hệ thống";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-header bg-primary text-white text-center">
                    <h4><i class="fas fa-sign-in-alt"></i> Đăng nhập</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                <form action="@Url.Action("Login", "Account")" method="post">
                    <div class="form-group mb-3">
                        <label class="font-weight-bold">Email đăng nhập</label>
                        <input type="email" name="email" class="form-control" placeholder="Nhập email..." required />
                    </div>
                    <div class="form-group mb-4">
                        <label class="font-weight-bold">Mật khẩu</label>
                        <input type="password" name="password" class="form-control" placeholder="Nhập mật khẩu..." required />
                    </div>
                    <input type="hidden" name="returnUrl" value="@ViewBag.ReturnUrl" />
                    <button type="submit" class="btn btn-primary w-100 btn-lg">Đăng nhập</button>
                </form>
                </div>
            </div>
        </div>
    </div>
</div>