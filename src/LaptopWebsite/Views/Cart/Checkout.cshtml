@{ ViewBag.Title = "Xác nhận thanh toán"; }

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white"><h5>Thông tin giao hàng</h5></div>
                <div class="card-body">
                    <form action="@Url.Action("ProcessCheckout", "Cart")" method="post">
                        <div class="mb-3">
                            <label>Người nhận: <strong>@Session["FullName"]</strong></label>
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Số điện thoại nhận hàng</label>
                            <input type="text" name="shipPhone" class="form-control" required />
                        </div>
                        <div class="mb-3">
                            <label class="form-label">Địa chỉ nhận hàng</label>
                            <textarea name="shipAddress" class="form-control" rows="3" required></textarea>
                        </div>
                        <hr />
                        <button type="submit" class="btn btn-success btn-lg w-100">XÁC NHẬN ĐẶT HÀNG</button>
                    </form>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card">
                <div class="card-body text-center">
                    <h6>Tổng tiền cần thanh toán:</h6>
                    <h3 class="text-danger">@ViewBag.TotalAmount.ToString("N0") đ</h3>
                </div>
            </div>
        </div>
    </div>
</div>