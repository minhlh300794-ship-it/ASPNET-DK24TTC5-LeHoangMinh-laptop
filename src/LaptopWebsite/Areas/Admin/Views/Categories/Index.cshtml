@model IEnumerable<LaptopWebsite.Models.Category>
@{ ViewBag.Title = "Quản lý Danh mục"; }

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="text-primary fw-bold"><i class="fas fa-tags"></i> Danh mục Thương hiệu</h4>
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="fas fa-plus-circle"></i> Thêm thương hiệu mới
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover align-middle border">
        <thead class="table-light">
            <tr>
                <th width="10%">ID</th>
                <th>Tên thương hiệu</th>
                <th width="20%" class="text-center">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>#@item.CategoryId</td>
                    <td class="fw-bold">@item.CategoryName</td>
                    <td class="text-center">
                        <a href="@Url.Action("Edit", new { id = item.CategoryId })" class="btn btn-sm btn-outline-warning">
                            <i class="fas fa-edit"></i>
                        </a>
                        <a href="@Url.Action("Delete", new { id = item.CategoryId })" class="btn btn-sm btn-outline-danger">
                            <i class="fas fa-trash"></i>
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>