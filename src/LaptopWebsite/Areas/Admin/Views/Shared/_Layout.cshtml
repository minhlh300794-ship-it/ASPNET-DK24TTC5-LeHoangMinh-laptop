<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewBag.Title - Hệ thống Quản trị</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        /* Style cho thanh menu bên trái */
        .sidebar {
            min-height: 100vh;
            background-color: #343a40;
            color: white;
            width: 260px;
            position: fixed;
        }

            .sidebar .brand {
                padding: 20px;
                font-size: 1.2rem;
                font-weight: bold;
                text-transform: uppercase;
                letter-spacing: 1px;
                border-bottom: 1px solid #4b545c;
            }

            .sidebar a {
                color: #c2c7d0;
                text-decoration: none;
                padding: 15px 20px;
                display: block;
                border-bottom: 1px solid #4f5962;
                transition: all 0.3s;
            }

                .sidebar a:hover, .sidebar a.active {
                    background-color: #007bff;
                    color: white;
                    border-left: 4px solid #0056b3;
                    padding-left: 16px;
                }

        /* Style cho phần nội dung chính */
        .main-wrapper {
            margin-left: 260px;
            width: calc(100% - 260px);
        }

        .top-navbar {
            background-color: white;
            padding: 15px 30px;
            box-shadow: 0 2px 4px rgba(0,0,0,.04);
            margin-bottom: 30px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .content-body {
            padding: 0 30px 30px 30px;
        }

        .card-custom {
            background: white;
            border-radius: 8px;
            padding: 25px;
            box-shadow: 0 0 15px rgba(0,0,0,.05);
        }

        /* Chỉnh lại style cho các bảng dữ liệu tự sinh */
        table.table {
            margin-top: 20px;
        }

        table th {
            background-color: #f8f9fa;
        }
    </style>
</head>
<body>
    <div class="d-flex">
        <div class="sidebar">
            <div class="brand text-center">
                <i class="fas fa-laptop-code text-info me-2"></i> Laptop Admin
            </div>
            <a href="/Admin/Products" class="active"><i class="fas fa-box-open me-2"></i> Quản lý Sản phẩm</a>
            <a href="@Url.Action("Index", "Categories", new { area = "Admin" })">
                <i class="fas fa-tags me-2"></i> Quản lý Danh mục
            </a>
            <a href="@Url.Action("Index", "Orders", new { area = "Admin" })">
                <i class="fas fa-shopping-cart me-2"></i> Quản lý Đơn hàng
            </a>
            <a href="#"><i class="fas fa-users me-2"></i> Quản lý Khách hàng</a>
            <a href="@Url.Action("Index", "Reports", new { area = "Admin" })">
                <i class="fas fa-chart-line me-2"></i> Báo cáo Doanh thu
            </a>
            <a href="/" class="text-warning mt-4 border-top-0"><i class="fas fa-external-link-alt me-2"></i> Xem Website (Front-end)</a>
        </div>

        <div class="main-wrapper">
            <div class="top-navbar">
                <h4 class="m-0 text-dark">@ViewBag.Title</h4>
                <div>
                    <span class="me-3 fw-bold text-secondary"><i class="fas fa-user-circle fa-lg me-1"></i> Admin</span>
                    <button class="btn btn-sm btn-outline-danger"><i class="fas fa-sign-out-alt"></i> Đăng xuất</button>
                </div>
            </div>

            <div class="content-body">
                <div class="card-custom">
                    @RenderBody()
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>