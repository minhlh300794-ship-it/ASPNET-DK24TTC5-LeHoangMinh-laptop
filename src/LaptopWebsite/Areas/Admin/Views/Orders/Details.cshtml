@model LaptopWebsite.Models.Order
@{ ViewBag.Title = "Chi tiết Đơn hàng #" + Model.OrderId; }

<div class="row">
    <div class="col-md-4 mb-4">
        <div class="card shadow h-100">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Thông tin & Xử lý</h5>
            </div>
            <div class="card-body">
                <p><strong>Người đặt:</strong> @Model.User.FullName</p>
                <p><strong>Điện thoại:</strong> @Model.User.Phone</p>
                <p><strong>Email:</strong> @Model.User.Email</p>
                <p><strong>Ngày đặt:</strong> @Model.OrderDate.ToString("dd/MM/yyyy HH:mm")</p>
                <hr />

                <form action="@Url.Action("UpdateStatus", "Orders")" method="post">
                    <input type="hidden" name="orderId" value="@Model.OrderId" />
                    <div class="mb-3">
                        <label class="form-label fw-bold">Tình trạng đơn hàng:</label>
                        <select name="status" class="form-select">
                            <option value="Chờ xử lý" @(Model.Status == "Chờ xử lý" ? "selected" : "")>⏳ Chờ xử lý</option>
                            <option value="Đang giao" @(Model.Status == "Đang giao" ? "selected" : "")>🚚 Đang giao hàng</option>
                            <option value="Đã giao" @(Model.Status == "Đã giao" ? "selected" : "")>✅ Đã giao thành công</option>
                            <option value="Đã hủy" @(Model.Status == "Đã hủy" ? "selected" : "")>❌ Đã hủy</option>
                        </select>
                    </div>
                    <button type="submit" class="btn btn-warning w-100 fw-bold">Cập nhật trạng thái</button>
                </form>
            </div>
        </div>
    </div>

    <div class="col-md-8 mb-4">
        <div class="card shadow h-100">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Sản phẩm khách mua</h5>
            </div>
            <div class="card-body">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Sản phẩm</th>
                            <th>Hình ảnh</th>
                            <th>SL</th>
                            <th>Đơn giá</th>
                            <th>Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in ViewBag.OrderDetails as IEnumerable<LaptopWebsite.Models.OrderDetail>)
                        {
                            <tr>
                                <td>@item.Product.ProductName</td>
                                <td><img src="@item.Product.ImageUrl" width="60" class="rounded border" /></td>
                                <td>@item.Quantity</td>
                                <td>@item.UnitPrice.ToString("N0") đ</td>
                                <td class="text-danger fw-bold">@((item.Quantity * item.UnitPrice).ToString("N0")) đ</td>
                            </tr>
                        }
                    </tbody>
                </table>
                <div class="text-end mt-4">
                    <h4>Tổng thanh toán: <span class="text-danger fw-bold">@Model.TotalAmount.ToString("N0") VNĐ</span></h4>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="mt-3">
    <a href="@Url.Action("Index", "Orders")" class="btn btn-secondary">Quay lại danh sách</a>
</div>